ai-knowledge-base/
*.pdf
data/
documents/

# ── Qdrant local storage (if mounted in-repo) ─────────────
qdrant_storage/

# ── IDE / OS ──────────────────────────────────────────────
.vscode/
.idea/
.DS_Store

# ── Local project docs (deployment specifics, not for public repo) ────────
docs/
