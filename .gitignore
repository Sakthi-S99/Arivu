# ── Python ────────────────────────────────────────────────
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# ── Environment / secrets ─────────────────────────────────
.env
*.env

# ── Runtime state & logs ──────────────────────────────────
.ingest_state.json
.ingest.lock
*.log

# ── Local domain config — keeps your vocabulary out of the public repo ────
config/acronyms.local.json

# ── Knowledge base — NEVER commit source documents ────────
